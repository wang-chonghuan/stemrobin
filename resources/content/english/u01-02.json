  "sentences": [
    {
      "text": "This is my body.",
      "gloss": "这是我的身体。",
      "pattern": "p1",
      "slots": ["body"],
      "targets": ["body"]
    },
    {
      "text": "I have one head, two arms, two legs and two feet.",
      "gloss": "我有一个头、两条手臂、两条腿和两只脚。",
      "targets": ["head", "arm", "leg", "foot"]
    },
    {
      "text": "On my face I have two eyes, two ears, a nose and a mouth.",
      "gloss": "我脸上有两只眼睛、两只耳朵、一个鼻子和一张嘴。",
      "targets": ["face", "eye", "ear", "nose", "mouth"]
    },
    {
      "text": "Every morning I wash my face and my hands with water and soap.",
      "gloss": "每天早上我用水和肥皂洗脸、洗手。",
      "pattern": "p2",
      "slots": ["face"],
      "targets": ["every", "wash", "hand", "water", "soap"]
    },
    {
      "text": "Then I dry my ten fingers on a towel.",
      "gloss": "然后我用毛巾把十根手指擦干。",
      "targets": ["dry", "finger", "towel"]
    },
    {
      "text": "I brush my teeth every day, and I brush my hair too.",
      "gloss": "我每天刷牙，也梳头发。",
      "pattern": "p3",
      "slots": ["teeth"],
      "targets": ["brush", "tooth", "hair"]
    },
    {
      "text": "Now I am clean from my head to my feet.",
      "gloss": "现在我从头到脚都干干净净。",
      "targets": ["clean"]
    }
  ]
}
