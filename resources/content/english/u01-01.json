  "sentences": [
    {
      "text": "Hello! My name is Ana.",
      "gloss": "你好！我叫安娜。",
      "pattern": "p1",
      "slots": ["Ana"],
      "targets": ["hello", "name"]
    },
    {
      "text": "I am nine years old, and I live with my family.",
      "gloss": "我九岁，和家人住在一起。",
      "pattern": "p2",
      "slots": ["nine"],
      "targets": ["old", "year", "live", "family"]
    },
    {
      "text": "This is my mother, and this is my father.",
      "gloss": "这是我妈妈，这是我爸爸。",
      "pattern": "p3",
      "slots": ["mother"],
      "targets": ["this", "mother", "father"]
    },
    {
      "text": "I have one brother and one sister.",
      "gloss": "我有一个弟弟和一个姐姐。",
      "pattern": "p4",
      "slots": ["brother"],
      "targets": ["have", "brother", "sister"]
    },
    {
      "text": "My brother is a baby boy, and my sister is a big girl.",
      "gloss": "我弟弟是个小男婴，我姐姐是个大女孩。",
      "targets": ["baby", "boy", "girl"]
    },
    {
      "text": "My grandmother and my grandfather live near us.",
      "gloss": "我奶奶和我爷爷住在我们附近。",
      "targets": ["grandmother", "grandfather"]
    },
    {
      "text": "On Sunday my aunt and my uncle come with my friend Ben.",
      "gloss": "星期天，我姑姑和我叔叔会带着我的朋友本一起来。",
      "targets": ["aunt", "uncle", "friend"]
    },
    {
      "text": "I love my family, and I want you to meet them.",
      "gloss": "我爱我的家人，我想让你见见他们。",
      "targets": ["love", "meet"]
    }
  ]
