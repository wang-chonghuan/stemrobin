  "sentences": [
    {
      "text": "It is nine o'clock, and it is time for bed.",
      "gloss": "九点了，该上床睡觉了。",
      "pattern": "p1",
      "slots": [
        "bed"
      ],
      "targets": []
    },
    {
      "text": "I am tired tonight, so I say goodbye to my toys.",
      "gloss": "今晚我很累，所以我跟玩具们说再见。",
      "targets": [
        "tired",
        "tonight",
        "goodbye"
      ]
    },
    {
      "text": "My mother reads me a short story for ten minutes, then she turns off the lamp.",
      "gloss": "妈妈给我读了十分钟的小故事，然后关上台灯。",
      "targets": [
        "story",
        "minute",
        "turn",
        "off",
        "lamp"
      ]
    },
    {
      "text": "My room is dark and quiet, and my bed is warm and soft.",
      "gloss": "我的房间又黑又安静，我的床又暖又软。",
      "targets": [
        "dark",
        "quiet",
        "warm",
        "soft"
      ]
    },
    {
      "text": "I lie down and rest, but I can't sleep.",
      "gloss": "我躺下休息，可是睡不着。",
      "pattern": "p3",
      "targets": [
        "lie",
        "rest",
        "sleep"
      ]
    },
    {
      "text": "I look out of the window at the moon.",
      "gloss": "我看着窗外的月亮。",
      "targets": [
        "moon"
      ]
    },
    {
      "text": "Half an hour later I am asleep, and I dream about my friends.",
      "gloss": "半小时后我睡着了，梦见了我的朋友们。",
      "targets": [
        "hour",
        "asleep",
        "dream"
      ]
    },
    {
      "text": "Good night! Tomorrow it all begins again.",
      "gloss": "晚安！明天这一切又要重新开始。",
      "pattern": "p4",
      "targets": [
        "night",
        "tomorrow",
        "again"
      ]
    }
  ]
}
