        {
          "svg": "<svg viewBox=\"0 0 700 150\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"解一元一次方程的四步路线图\">\n        <defs>\n          <marker id=\"arw\" markerWidth=\"9\" markerHeight=\"9\" refX=\"7\" refY=\"4.5\" orient=\"auto\">\n            <path d=\"M0,0 L9,4.5 L0,9 z\" fill=\"#0A5E76\"/>\n          </marker>\n        </defs>\n        <g font-family=\"Noto Sans SC, sans-serif\" font-size=\"14\">\n          <rect x=\"14\"  y=\"46\" width=\"150\" height=\"58\" rx=\"9\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n          <text x=\"89\"  y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0A5E76\">① 合并同类项</text>\n          <text x=\"89\"  y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">把两边各自变短</text>\n\n          <rect x=\"192\" y=\"46\" width=\"150\" height=\"58\" rx=\"9\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n          <text x=\"267\" y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0A5E76\">② 移项</text>\n          <text x=\"267\" y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">未知数归一边</text>\n\n          <rect x=\"370\" y=\"46\" width=\"150\" height=\"58\" rx=\"9\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n          <text x=\"445\" y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0A5E76\">③ 除系数</text>\n          <text x=\"445\" y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">系数变成 1</text>\n\n          <rect x=\"548\" y=\"46\" width=\"138\" height=\"58\" rx=\"9\" fill=\"#E4F6EE\" stroke=\"#15A06A\"/>\n          <text x=\"617\" y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0F7D52\">④ 检验</text>\n          <text x=\"617\" y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">代入原方程</text>\n\n          <line x1=\"164\" y1=\"75\" x2=\"190\" y2=\"75\" stroke=\"#0A5E76\" stroke-width=\"2\" marker-end=\"url(#arw)\"/>\n          <line x1=\"342\" y1=\"75\" x2=\"368\" y2=\"75\" stroke=\"#0A5E76\" stroke-width=\"2\" marker-end=\"url(#arw)\"/>\n          <line x1=\"520\" y1=\"75\" x2=\"546\" y2=\"75\" stroke=\"#0A5E76\" stroke-width=\"2\" marker-end=\"url(#arw)\"/>\n\n          <text x=\"350\" y=\"28\" text-anchor=\"middle\" font-size=\"13\" fill=\"#8A9795\">前三步让未知数孤立，第四步确认答案</text>\n          <text x=\"350\" y=\"132\" text-anchor=\"middle\" font-size=\"12\" fill=\"#8A9795\">哪一步没事可做就跳过，但顺序不变</text>\n        </g>\n      </svg>",
