        {
          "svg": "<svg viewBox=\"0 0 700 150\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"方程应用题的四步路线图\">\n        <defs>\n          <marker id=\"arw\" markerWidth=\"9\" markerHeight=\"9\" refX=\"7\" refY=\"4.5\" orient=\"auto\">\n            <path d=\"M0,0 L9,4.5 L0,9 z\" fill=\"#0A5E76\"/>\n          </marker>\n        </defs>\n        <g font-family=\"Noto Sans SC, sans-serif\" font-size=\"14\">\n          <rect x=\"10\"  y=\"46\" width=\"156\" height=\"58\" rx=\"9\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n          <text x=\"88\"  y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0A5E76\">① 设未知数</text>\n          <text x=\"88\"  y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">带单位地设 x</text>\n\n          <rect x=\"188\" y=\"46\" width=\"156\" height=\"58\" rx=\"9\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n          <text x=\"266\" y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0A5E76\">② 写等量关系句</text>\n          <text x=\"266\" y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">先写一句 A=B</text>\n\n          <rect x=\"366\" y=\"46\" width=\"156\" height=\"58\" rx=\"9\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n          <text x=\"444\" y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0A5E76\">③ 列方程</text>\n          <text x=\"444\" y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">把那句话翻译成式子</text>\n\n          <rect x=\"544\" y=\"46\" width=\"146\" height=\"58\" rx=\"9\" fill=\"#E4F6EE\" stroke=\"#15A06A\"/>\n          <text x=\"617\" y=\"70\" text-anchor=\"middle\" font-weight=\"700\" fill=\"#0F7D52\">④ 解并作答</text>\n          <text x=\"617\" y=\"90\" text-anchor=\"middle\" fill=\"#4C5A58\" font-size=\"12\">回到问题带单位</text>\n\n          <line x1=\"166\" y1=\"75\" x2=\"186\" y2=\"75\" stroke=\"#0A5E76\" stroke-width=\"2\" marker-end=\"url(#arw)\"/>\n          <line x1=\"344\" y1=\"75\" x2=\"364\" y2=\"75\" stroke=\"#0A5E76\" stroke-width=\"2\" marker-end=\"url(#arw)\"/>\n          <line x1=\"522\" y1=\"75\" x2=\"542\" y2=\"75\" stroke=\"#0A5E76\" stroke-width=\"2\" marker-end=\"url(#arw)\"/>\n\n          <text x=\"350\" y=\"26\" text-anchor=\"middle\" font-size=\"13\" fill=\"#8A9795\">本课重点在 ①②③——把文字变成方程</text>\n          <text x=\"350\" y=\"132\" text-anchor=\"middle\" font-size=\"12\" fill=\"#8A9795\">第④步的\"解\"用上一课已经学会的方法</text>\n        </g>\n      </svg>",
