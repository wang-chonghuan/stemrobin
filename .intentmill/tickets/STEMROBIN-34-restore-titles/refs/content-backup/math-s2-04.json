          "svg": "<svg viewBox=\"0 0 640 320\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"项 -3x²y 的身份证：系数与次数\">\n        <!-- top: the term -->\n        <rect x=\"245\" y=\"18\" width=\"150\" height=\"40\" rx=\"8\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\" stroke-width=\"1.5\"/>\n        <text x=\"320\" y=\"44\" text-anchor=\"middle\" font-size=\"19\" font-weight=\"700\" fill=\"#0A5E76\" font-family=\"JetBrains Mono, monospace\">−3x²y</text>\n        <text x=\"418\" y=\"44\" font-size=\"12\" fill=\"#8A9795\">…一个项</text>\n        <!-- arrows down -->\n        <line x1=\"320\" y1=\"58\" x2=\"110\" y2=\"118\" stroke=\"#8A9795\" stroke-width=\"1.4\"/>\n        <line x1=\"320\" y1=\"58\" x2=\"250\" y2=\"118\" stroke=\"#8A9795\" stroke-width=\"1.4\"/>\n        <line x1=\"320\" y1=\"58\" x2=\"390\" y2=\"118\" stroke=\"#8A9795\" stroke-width=\"1.4\"/>\n        <line x1=\"320\" y1=\"58\" x2=\"530\" y2=\"118\" stroke=\"#8A9795\" stroke-width=\"1.4\"/>\n        <text x=\"320\" y=\"95\" text-anchor=\"middle\" font-size=\"12\" fill=\"#4C5A58\">打开乘法层（x² = x·x）</text>\n        <!-- factor boxes -->\n        <rect x=\"72\" y=\"120\" width=\"76\" height=\"38\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#0E7C9B\" stroke-width=\"1.5\"/>\n        <text x=\"110\" y=\"145\" text-anchor=\"middle\" font-size=\"17\" font-weight=\"700\" fill=\"#0A5E76\" font-family=\"JetBrains Mono, monospace\">−3</text>\n        <rect x=\"212\" y=\"120\" width=\"76\" height=\"38\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#15A06A\" stroke-width=\"1.5\"/>\n        <text x=\"250\" y=\"145\" text-anchor=\"middle\" font-size=\"17\" font-weight=\"700\" fill=\"#0F7D52\" font-family=\"JetBrains Mono, monospace\">x</text>\n        <rect x=\"352\" y=\"120\" width=\"76\" height=\"38\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#15A06A\" stroke-width=\"1.5\"/>\n        <text x=\"390\" y=\"145\" text-anchor=\"middle\" font-size=\"17\" font-weight=\"700\" fill=\"#0F7D52\" font-family=\"JetBrains Mono, monospace\">x</text>\n        <rect x=\"492\" y=\"120\" width=\"76\" height=\"38\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#15A06A\" stroke-width=\"1.5\"/>\n        <text x=\"530\" y=\"145\" text-anchor=\"middle\" font-size=\"17\" font-weight=\"700\" fill=\"#0F7D52\" font-family=\"JetBrains Mono, monospace\">y</text>\n        <!-- multiplication dots between boxes -->\n        <text x=\"180\" y=\"145\" text-anchor=\"middle\" font-size=\"16\" fill=\"#8A9795\">·</text>\n        <text x=\"320\" y=\"145\" text-anchor=\"middle\" font-size=\"16\" fill=\"#8A9795\">·</text>\n        <text x=\"460\" y=\"145\" text-anchor=\"middle\" font-size=\"16\" fill=\"#8A9795\">·</text>\n        <!-- label: numeric factor -> coefficient -->\n        <line x1=\"110\" y1=\"158\" x2=\"110\" y2=\"196\" stroke=\"#0E7C9B\" stroke-width=\"1.4\"/>\n        <rect x=\"34\" y=\"198\" width=\"152\" height=\"52\" rx=\"8\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\" stroke-width=\"1.2\"/>\n        <text x=\"110\" y=\"220\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" fill=\"#0A5E76\">数字因数（带符号）</text>\n        <text x=\"110\" y=\"240\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"700\" fill=\"#0A5E76\">系数 = −3</text>\n        <!-- brace over letter factors -->\n        <path d=\"M 212 168 L 212 178 L 568 178 L 568 168\" fill=\"none\" stroke=\"#15A06A\" stroke-width=\"1.4\"/>\n        <line x1=\"390\" y1=\"178\" x2=\"390\" y2=\"196\" stroke=\"#15A06A\" stroke-width=\"1.4\"/>\n        <rect x=\"300\" y=\"198\" width=\"180\" height=\"52\" rx=\"8\" fill=\"#E4F6EE\" stroke=\"#15A06A\" stroke-width=\"1.2\"/>\n        <text x=\"390\" y=\"220\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" fill=\"#0F7D52\">字母因数：x、x、y 共 3 个</text>\n        <text x=\"390\" y=\"240\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"700\" fill=\"#0F7D52\">次数 = 3</text>\n        <!-- identity card summary -->\n        <rect x=\"130\" y=\"272\" width=\"380\" height=\"34\" rx=\"8\" fill=\"#F5F9F9\" stroke=\"#E3EAE9\"/>\n        <text x=\"320\" y=\"294\" text-anchor=\"middle\" font-size=\"13.5\" font-weight=\"700\" fill=\"#15201F\">−3x²y 的身份证：系数 −3 ｜ 次数 3</text>\n      </svg>",
