        {
          "svg": "<svg viewBox=\"0 0 680 330\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"整式加减两棒接力：去括号、合并同类项，最后用代入检验\">\n        <text x=\"20\" y=\"28\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"13\" font-weight=\"600\" fill=\"#15201F\">求 (3a−2) − (a−5)：两棒接力 + 代入检验</text>\n\n        <!-- 起点式子 -->\n        <rect x=\"30\" y=\"48\" width=\"230\" height=\"40\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#E3EAE9\"/>\n        <text x=\"145\" y=\"74\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"17\" fill=\"#15201F\">(3a−2) − (a−5)</text>\n\n        <!-- 第一棒 -->\n        <path d=\"M 145 88 L 145 122\" fill=\"none\" stroke=\"#0E7C9B\" stroke-width=\"1.8\" marker-end=\"url(#ah1)\"/>\n        <text x=\"160\" y=\"110\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"12\" fill=\"#0A5E76\">第一棒：去括号（−1 分配进每一项，全变号）</text>\n\n        <rect x=\"30\" y=\"128\" width=\"230\" height=\"40\" rx=\"8\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\"/>\n        <text x=\"145\" y=\"154\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"17\" fill=\"#0A5E76\">3a − 2 − a + 5</text>\n\n        <!-- 第二棒 -->\n        <path d=\"M 145 168 L 145 202\" fill=\"none\" stroke=\"#15A06A\" stroke-width=\"1.8\" marker-end=\"url(#ah2)\"/>\n        <text x=\"160\" y=\"190\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"12\" fill=\"#0F7D52\">第二棒：合并同类项（系数相加，字母不动）</text>\n\n        <rect x=\"30\" y=\"208\" width=\"230\" height=\"40\" rx=\"8\" fill=\"#E4F6EE\" stroke=\"#15A06A\"/>\n        <text x=\"145\" y=\"234\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"17\" fill=\"#0F7D52\">2a + 3</text>\n\n        <text x=\"30\" y=\"278\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"12\" fill=\"#8A9795\">终点检查：没括号了？没同类项了？——是最简，停笔。</text>\n\n        <!-- 代入检验框 -->\n        <rect x=\"400\" y=\"70\" width=\"250\" height=\"160\" rx=\"8\" fill=\"#F5F9F9\" stroke=\"#E3EAE9\"/>\n        <text x=\"416\" y=\"96\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"13\" font-weight=\"600\" fill=\"#15201F\">代入检验：代 a = 1</text>\n        <text x=\"416\" y=\"126\" font-family=\"JetBrains Mono, monospace\" font-size=\"13\" fill=\"#15201F\">原式 = (3−2) − (1−5)</text>\n        <text x=\"416\" y=\"148\" font-family=\"JetBrains Mono, monospace\" font-size=\"13\" fill=\"#15201F\">　　 = 1 − (−4) = 5</text>\n        <text x=\"416\" y=\"178\" font-family=\"JetBrains Mono, monospace\" font-size=\"13\" fill=\"#15201F\">结果 = 2×1 + 3 = 5</text>\n        <text x=\"416\" y=\"208\" font-family=\"JetBrains Mono, monospace\" font-size=\"13\" fill=\"#0F7D52\">5 = 5 ✓ 两边一致</text>\n\n        <!-- 连线：起点与终点都指向检验 -->\n        <path d=\"M 260 68 C 330 68, 360 90, 398 100\" fill=\"none\" stroke=\"#8A9795\" stroke-width=\"1.4\" stroke-dasharray=\"4 3\" marker-end=\"url(#ah3)\"/>\n        <path d=\"M 260 228 C 330 228, 360 206, 398 196\" fill=\"none\" stroke=\"#8A9795\" stroke-width=\"1.4\" stroke-dasharray=\"4 3\" marker-end=\"url(#ah3)\"/>\n\n        <text x=\"30\" y=\"310\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"12\" fill=\"#8A9795\">化简只是换写法，值不变——所以化简前后代同一个数，结果必须相等。</text>\n\n        <defs>\n          <marker id=\"ah1\" markerWidth=\"8\" markerHeight=\"8\" refX=\"4\" refY=\"4\" orient=\"auto\"><path d=\"M0,0 L8,4 L0,8 Z\" fill=\"#0E7C9B\"/></marker>\n          <marker id=\"ah2\" markerWidth=\"8\" markerHeight=\"8\" refX=\"4\" refY=\"4\" orient=\"auto\"><path d=\"M0,0 L8,4 L0,8 Z\" fill=\"#15A06A\"/></marker>\n          <marker id=\"ah3\" markerWidth=\"8\" markerHeight=\"8\" refX=\"4\" refY=\"4\" orient=\"auto\"><path d=\"M0,0 L8,4 L0,8 Z\" fill=\"#8A9795\"/></marker>\n        </defs>\n      </svg>",
