        {
          "svg": "<svg viewBox=\"0 0 680 300\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"因数 −1 按分配律分别乘进括号里的两项\">\n        <!-- top: the expression, minus read as factor -1 -->\n        <text x=\"340\" y=\"40\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"20\" fill=\"#15201F\">−(a − b)　读作　(−1) × (a − b)</text>\n\n        <!-- the factor -1 box -->\n        <rect x=\"290\" y=\"66\" width=\"100\" height=\"38\" rx=\"8\" fill=\"#E1F1F5\" stroke=\"#0E7C9B\" stroke-width=\"2\"/>\n        <text x=\"340\" y=\"91\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"17\" font-weight=\"600\" fill=\"#0A5E76\">因数 −1</text>\n\n        <!-- two terms inside the bracket -->\n        <rect x=\"130\" y=\"160\" width=\"150\" height=\"40\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#15A06A\" stroke-width=\"2\"/>\n        <text x=\"205\" y=\"186\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"16\" fill=\"#15201F\">第一项 a</text>\n        <rect x=\"400\" y=\"160\" width=\"150\" height=\"40\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#15A06A\" stroke-width=\"2\"/>\n        <text x=\"475\" y=\"186\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"16\" fill=\"#15201F\">第二项 −b</text>\n\n        <!-- arrows from factor to each term (hand-drawn curves) -->\n        <path d=\"M 305 104 C 260 125, 230 140, 212 156\" fill=\"none\" stroke=\"#0E7C9B\" stroke-width=\"2.5\"/>\n        <path d=\"M 212 156 l 2 -9 M 212 156 l 9 -2\" stroke=\"#0E7C9B\" stroke-width=\"2.5\" fill=\"none\"/>\n        <path d=\"M 375 104 C 420 125, 450 140, 468 156\" fill=\"none\" stroke=\"#0E7C9B\" stroke-width=\"2.5\"/>\n        <path d=\"M 468 156 l -9 -2 M 468 156 l -2 -9\" stroke=\"#0E7C9B\" stroke-width=\"2.5\" fill=\"none\"/>\n        <text x=\"215\" y=\"130\" text-anchor=\"middle\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"12\" fill=\"#0A5E76\">乘一次</text>\n        <text x=\"465\" y=\"130\" text-anchor=\"middle\" font-family=\"Hanken Grotesk, sans-serif\" font-size=\"12\" fill=\"#0A5E76\">也要乘一次</text>\n\n        <!-- results -->\n        <text x=\"205\" y=\"236\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"15\" fill=\"#0F7D52\">(−1)×a = −a</text>\n        <text x=\"475\" y=\"236\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"15\" fill=\"#0F7D52\">(−1)×(−b) = +b</text>\n\n        <!-- final line -->\n        <text x=\"340\" y=\"278\" text-anchor=\"middle\" font-family=\"JetBrains Mono, monospace\" font-size=\"18\" font-weight=\"600\" fill=\"#15201F\">所以 −(a − b) = −a + b</text>\n      </svg>",
